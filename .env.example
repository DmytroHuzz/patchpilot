# PatchPilot reads variables from the launching shell; this file is a reference and is not auto-loaded.

# Optional: enable live GPT-5.6 Responses API calls instead of checked-in cached-demo fixtures.
OPENAI_API_KEY=

# Optional: override the verified scanner installed by scripts/setup-osv-scanner.sh.
OSV_SCANNER_PATH=

# Optional: local loopback server port (default 4173).
PORT=4173
